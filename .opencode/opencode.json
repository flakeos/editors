{
  "$schema": "https://opencode.ai/config.json",
  "logLevel": "ERROR",
  "share": "disabled",
  "autoupdate": false,
  "formatter": false,
  "lsp": false,
  "snapshot": false,
  "permission": {
    "edit": "allow",
    "bash": { "git *": "allow", "*": "ask" },
    "external_directory": "ask",
    "websearch": "allow",
    "webfetch": "allow"
  },
  "tool_output": { "max_lines": 500, "max_bytes": 16384 },
  "compaction": { "auto": true, "tail_turns": 3 }
}
