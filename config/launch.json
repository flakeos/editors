{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Go: Debug Package",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}"
    },
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Java: Debug Current",
      "type": "java",
      "request": "launch",
      "mainClass": "${file}"
    },
    {
      "name": "Node: Current File",
      "type": "node",
      "request": "launch",
      "program": "${file}"
    }
  ]
}
